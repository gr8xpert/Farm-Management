# Database (MySQL) - Update with your Plesk database credentials
DATABASE_URL="mysql://db_username:db_password@localhost:3306/farm_management"

# JWT Secret - Change this to a random secure string
JWT_SECRET="change-this-to-a-secure-random-string-in-production"
JWT_EXPIRES_IN="24h"

# Server
PORT=3001
NODE_ENV=production

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Authentication & Users
model User {
  user_id      Int       @id @default(autoincrement())
  username     String    @unique @db.VarChar(50)
  email        String    @unique @db.VarChar(100)
  password_hash String   @db.VarChar(255)
  role         Role      @default(STAFF)
  active       Boolean   @default(true)
  created_on   DateTime  @default(now())
  last_login   DateTime?

  @@map("users")
}

enum Role {
  ADMIN
  STAFF
}

// Suppliers
model Supplier {
  supplier_id     Int       @id @default(autoincrement())
  supplier_name   String    @db.VarChar(100)
  contact_person  String?   @db.VarChar(100)
  country         String?   @db.VarChar(50)
  state           String?   @db.VarChar(50)
  city            String?   @db.VarChar(50)
  address         String?   @db.VarChar(255)
  email_address   String?   @db.VarChar(100)
  webpage_address String?   @db.VarChar(255)
  phone_number    String?   @db.VarChar(20)
  created_by      String?   @db.VarChar(50)
  created_on      DateTime  @default(now())
  computer_name   String?   @db.VarChar(50)
  active          Boolean   @default(true)

  purchases       PurchaseMaster[]
  purchaseReturns PurchaseReturnMaster[]
  payments        Payment[]

  @@map("suppliers")
}

// Customers
model Customer {
  customer_id     Int       @id @default(autoincrement())
  customer_name   String    @db.VarChar(100)
  contact_person  String?   @db.VarChar(100)
  country         String?   @db.VarChar(50)
  state           String?   @db.VarChar(50)
  city            String?   @db.VarChar(50)
  address         String?   @db.VarChar(255)
  email_address   String?   @db.VarChar(100)
  webpage_address String?   @db.VarChar(255)
  phone_number    String?   @db.VarChar(20)
  created_by      String?   @db.VarChar(50)
  created_on      DateTime  @default(now())
  computer_name   String?   @db.VarChar(50)
  active          Boolean   @default(true)

  sales           SaleMaster[]
  saleReturns     SaleReturnMaster[]
  payments        Payment[]

  @@map("customers")
}

// Item Categories
model Category {
  category_id   Int       @id @default(autoincrement())
  category_name String    @db.VarChar(100)
  description   String?   @db.VarChar(255)
  active        Boolean   @default(true)
  created_on    DateTime  @default(now())

  items         Item[]

  @@map("categories")
}

model WeightUnit {
  unit_id     Int      @id @default(autoincrement())
  unit_name   String   @db.VarChar(50)
  description String?  @db.VarChar(255)
  active      Boolean  @default(true)
  created_on  DateTime @default(now())

  @@map("weight_units")
}

model City {
  city_id     Int      @id @default(autoincrement())
  city_name   String   @db.VarChar(100)
  description String?  @db.VarChar(255)
  active      Boolean  @default(true)
  created_on  DateTime @default(now())

  @@map("cities")
}

// Items
model Item {
  item_id           Int       @id @default(autoincrement())
  items_description String    @db.VarChar(255)
  category_id       Int?
  category          Category? @relation(fields: [category_id], references: [category_id])
  remarks           String?   @db.VarChar(255)
  created_on        DateTime  @default(now())
  created_by        String?   @db.VarChar(50)
  computer_name     String?   @db.VarChar(50)
  active            Boolean   @default(true)

  purchaseDetails       PurchaseDetail[]
  saleDetails           SaleDetail[]
  purchaseReturnDetails PurchaseReturnDetail[]
  saleReturnDetails     SaleReturnDetail[]

  @@map("items")
}

// Banks
model Bank {
  bank_id       Int       @id @default(autoincrement())
  bank_name     String    @db.VarChar(100)
  active        Boolean   @default(true)
  created_on    DateTime  @default(now())
  created_by    String?   @db.VarChar(50)
  computer_name String?   @db.VarChar(50)
  company_id    Int?

  payments      Payment[]

  @@map("banks")
}

// Employees
model Employee {
  employee_no    Int       @id @default(autoincrement())
  employee_name  String    @db.VarChar(100)
  father_name    String?   @db.VarChar(100)
  dob            DateTime?
  doj            DateTime?
  nic_no         String?   @db.VarChar(20)
  city           String?   @db.VarChar(50)
  state          String?   @db.VarChar(50)
  address        String?   @db.VarChar(255)
  phone_no       String?   @db.VarChar(20)
  mobile_no      String?   @db.VarChar(20)
  status         String?   @db.VarChar(20) @default("active")
  ref_name       String?   @db.VarChar(100)
  monthly_salary Decimal?  @db.Decimal(12, 2)
  active         Boolean   @default(true)

  payments       Payment[]

  @@map("employees")
}

// Purchase Master
model PurchaseMaster {
  po_no       Int       @id @default(autoincrement())
  po_date     DateTime  @default(now())
  supplier_id Int
  supplier    Supplier  @relation(fields: [supplier_id], references: [supplier_id])
  remarks     String?   @db.VarChar(255)
  ref_name    String?   @db.VarChar(100)
  created_by  String?   @db.VarChar(50)
  created_on  DateTime  @default(now())
  total_amount Decimal? @db.Decimal(12, 2)

  details         PurchaseDetail[]
  purchaseReturns PurchaseReturnMaster[]
  payments        Payment[]

  @@map("purchase_master")
}

// Purchase Detail
model PurchaseDetail {
  id        Int       @id @default(autoincrement())
  po_no     Int
  purchase  PurchaseMaster @relation(fields: [po_no], references: [po_no], onDelete: Cascade)
  sno       Int
  item_id   Int
  item      Item      @relation(fields: [item_id], references: [item_id])
  qty       Decimal   @db.Decimal(10, 2)
  price     Decimal   @db.Decimal(10, 2)
  age       Int?
  weight      Decimal?  @db.Decimal(10, 2)
  weight_unit String?   @db.VarChar(20)
  remarks     String?   @db.VarChar(255)

  @@map("purchase_detail")
}

// Sale Master
model SaleMaster {
  sale_id      Int       @id @default(autoincrement())
  sale_date    DateTime  @default(now())
  customer_id  Int
  customer     Customer  @relation(fields: [customer_id], references: [customer_id])
  remarks      String?   @db.VarChar(255)
  ref_name     String?   @db.VarChar(100)
  created_by   String?   @db.VarChar(50)
  created_on   DateTime  @default(now())
  total_amount Decimal?  @db.Decimal(12, 2)

  details      SaleDetail[]
  saleReturns  SaleReturnMaster[]
  payments     Payment[]

  @@map("sale_master")
}

// Sale Detail
model SaleDetail {
  id        Int       @id @default(autoincrement())
  sale_id   Int
  sale      SaleMaster @relation(fields: [sale_id], references: [sale_id], onDelete: Cascade)
  sno       Int
  item_id   Int
  item      Item      @relation(fields: [item_id], references: [item_id])
  qty       Decimal   @db.Decimal(10, 2)
  price     Decimal   @db.Decimal(10, 2)
  age       Int?
  weight      Decimal?  @db.Decimal(10, 2)
  weight_unit String?   @db.VarChar(20)
  remarks     String?   @db.VarChar(255)

  @@map("sale_detail")
}

// Payments
model Payment {
  payment_id      Int       @id @default(autoincrement())
  payment_date    DateTime  @default(now())
  payment_amount  Decimal   @db.Decimal(12, 2)
  payment_mode    PaymentMode
  payment_type    PaymentType

  // Bank relation (from Banks table)
  bank_id         Int?
  bank            Bank?     @relation(fields: [bank_id], references: [bank_id])

  // Supplier relation (for payments TO suppliers)
  supplier_id     Int?
  supplier        Supplier? @relation(fields: [supplier_id], references: [supplier_id])

  // Customer relation (for payments FROM customers)
  customer_id     Int?
  customer        Customer? @relation(fields: [customer_id], references: [customer_id])

  // Purchase Order relation
  po_no           Int?
  purchase        PurchaseMaster? @relation(fields: [po_no], references: [po_no])

  // Sale relation
  sale_id         Int?
  sale            SaleMaster? @relation(fields: [sale_id], references: [sale_id])

  // Employee relation (for salary payments)
  employee_no     Int?
  employee        Employee? @relation(fields: [employee_no], references: [employee_no])
  salary_month    DateTime?
  salary_type     SalaryType?

  cheque_no       String?   @db.VarChar(50)
  cheque_date     DateTime?
  remarks         String?   @db.VarChar(255)
  created_by      String?   @db.VarChar(50)
  created_on      DateTime  @default(now())

  @@map("payments")
}

enum PaymentMode {
  CASH
  CHEQUE
  BANK_TRANSFER
  ONLINE
  CARD
}

enum PaymentType {
  PAYMENT
  RECEIPT
  REFUND
  SALARY
}

enum SalaryType {
  ADVANCE
  REGULAR
}

// Purchase Return Master
model PurchaseReturnMaster {
  pr_no         Int       @id @default(autoincrement())
  pr_date       DateTime  @default(now())
  po_no         Int
  purchase      PurchaseMaster @relation(fields: [po_no], references: [po_no])
  supplier_id   Int
  supplier      Supplier  @relation(fields: [supplier_id], references: [supplier_id])
  reason        ReturnReason
  ref_name      String?   @db.VarChar(100)
  created_by    String?   @db.VarChar(50)
  created_on    DateTime  @default(now())
  computer_name String?   @db.VarChar(50)
  total_amount  Decimal?  @db.Decimal(12, 2)

  details       PurchaseReturnDetail[]

  @@map("purchase_return_master")
}

// Purchase Return Detail
model PurchaseReturnDetail {
  id        Int       @id @default(autoincrement())
  pr_no     Int
  return    PurchaseReturnMaster @relation(fields: [pr_no], references: [pr_no], onDelete: Cascade)
  sno       Int
  item_id   Int
  item      Item      @relation(fields: [item_id], references: [item_id])
  qty       Decimal   @db.Decimal(10, 2)
  price     Decimal   @db.Decimal(10, 2)
  age       Int?
  weight      Decimal?  @db.Decimal(10, 2)
  weight_unit String?   @db.VarChar(20)
  remarks     String?   @db.VarChar(255)

  @@map("purchase_return_detail")
}

// Sale Return Master
model SaleReturnMaster {
  sr_no         Int       @id @default(autoincrement())
  sr_date       DateTime  @default(now())
  sale_id       Int
  sale          SaleMaster @relation(fields: [sale_id], references: [sale_id])
  customer_id   Int
  customer      Customer  @relation(fields: [customer_id], references: [customer_id])
  reason        ReturnReason
  ref_name      String?   @db.VarChar(100)
  created_by    String?   @db.VarChar(50)
  created_on    DateTime  @default(now())
  computer_name String?   @db.VarChar(50)
  total_amount  Decimal?  @db.Decimal(12, 2)

  details       SaleReturnDetail[]

  @@map("sale_return_master")
}

// Sale Return Detail
model SaleReturnDetail {
  id        Int       @id @default(autoincrement())
  sr_no     Int
  return    SaleReturnMaster @relation(fields: [sr_no], references: [sr_no], onDelete: Cascade)
  sno       Int
  item_id   Int
  item      Item      @relation(fields: [item_id], references: [item_id])
  qty       Decimal   @db.Decimal(10, 2)
  price     Decimal   @db.Decimal(10, 2)
  age       Int?
  weight      Decimal?  @db.Decimal(10, 2)
  weight_unit String?   @db.VarChar(20)
  remarks     String?   @db.VarChar(255)

  @@map("sale_return_detail")
}

enum ReturnReason {
  STALE
  DEFECTIVE
  WRONG_ITEM
  QUALITY_ISSUE
  OTHER
}

enum EntityType {
  PURCHASE_MASTER
  PURCHASE_DETAIL
  SALE_MASTER
  SALE_DETAIL
}

model Attachment {
  id            Int        @id @default(autoincrement())
  entity_type   EntityType
  entity_id     Int
  sno           Int?
  file_path     String     @db.VarChar(500)
  original_name String     @db.VarChar(255)
  mime_type     String?    @db.VarChar(100)
  file_size     Int?
  created_by    String?    @db.VarChar(50)
  created_on    DateTime   @default(now())

  @@index([entity_type, entity_id])
  @@index([entity_type, entity_id, sno])
  @@map("attachments")
}
